{
  "name": "san-agustin",
  "version": "1.0.0",
  "description": "Proyecto web centro medico San Agustin ",
  "homepage": "https://bitbucket.org/proyectoscruz21/san-agustin#readme",
  "bugs": {
    "url": "https://bitbucket.org/proyectoscruz21/san-agustin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://proyectoscruz21-admin@bitbucket.org/proyectoscruz21/san-agustin.git"
  },
  "license": "ISC",
  "author": "Steven Cruz",
  "type": "commonjs",
  "main": "index.html",
  "scripts": {
    "dev": "lite-server",
    "scss": "sass --no-source-map css/:css/",
    "watch:scss": "onchange 'css/*.scss' -- npm run scss",
    "start": "concurrently \"npm run watch:scss\" \"npm run dev\"",
    "build": "rimraf distri && gulp",
    "copy:dist": "copyfiles -u 1 \"*.html\" \"css/*.css\" \"img/**\" distri",
    "less": "lessc css/styles.less css/styles-less.css",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "copyfiles": "^2.4.1",
    "grunt": "^1.6.1",
    "grunt-browser-sync": "^2.2.0",
    "grunt-contrib-clean": "^2.0.1",
    "grunt-contrib-concat": "^2.1.0",
    "grunt-contrib-copy": "^1.0.0",
    "grunt-contrib-cssmin": "^5.0.0",
    "grunt-contrib-imagemin": "^4.0.0",
    "grunt-contrib-sass": "^2.0.0",
    "grunt-contrib-uglify": "^5.2.2",
    "grunt-filerev": "^2.3.1",
    "grunt-usemin": "^3.1.1",
    "gulp": "^5.0.1",
    "gulp-sass": "^6.0.1",
    "jit-grunt": "^0.10.0",
    "lite-server": "^2.6.1",
    "onchange": "^7.1.0",
    "rimraf": "^6.1.3",
    "sass": "^1.98.0",
    "less": "^4.4.3",
    "time-grunt": "^1.4.0"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "concurrently": "^9.2.1",
    "open-iconic": "^1.1.1"
  }
}
